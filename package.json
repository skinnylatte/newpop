    "@11ty/eleventy": "^3.1.2",
    "eleventy-plugin-youtube-embed": "^1.13.0",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.0.0"
  },
  "devDependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "clean-css": "^5.3.3",
    "dayjs": "^1.11.19",
    "luxon": "^3.4.4",
    "markdown-it-anchor": "^9.2.0",
    "pagefind": "^1.4.0",
    "slugify": "^1.6.6"
