{
  "name": "newpop",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf _site",
    "test": "npm run lint && npm run build",
    "lint": "npm run lint:frontmatter && npm run lint:design-system",
    "lint:frontmatter": "node scripts/check-frontmatter.js",
    "lint:design-system": "node scripts/check-design-system.js",
    "search:index": "npx pagefind --site _site --glob \"**/*.html\"",
    "start": "npx @11ty/eleventy --serve --incremental",
    "build:site": "npx @11ty/eleventy && node minify-css.js",
    "build:search": "npx pagefind --site _site --glob \"**/*.html\"",
    "build": "npm run clean && npm run build:site && npm run build:search"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
