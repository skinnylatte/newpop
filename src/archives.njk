---
title: The Archives
layout: layout.njk
tags:
 - archives
 - lists
eleventyExcludeFromCollections: true
---

<article class="archives">
    <h1>{{ title }}</h1>
    <div class="date-metadata">Browse all posts by year</div>

    {% set years = collections.postsByYear | dictsort(false, "key") | reverse %}
    {% if years.length > 0 %}
        <section class="archive-year-section">
            <h2>Years ({{ years.length }})</h2>
            <ul class="archive-years-list">
            {% for yearData in years %}
                {% set archiveYear = yearData[0] %}
                {% set archivePosts = yearData[1] %}
                <li class="archive-year-item">
                    <a href="/archives/{{ archiveYear }}/" class="archive-year-link">{{ archiveYear }}</a>
                    <span class="archive-year-count">{{ archivePosts.length }} post{% if archivePosts.length != 1 %}s{% endif %}</span>
                </li>
            {% endfor %}
            </ul>
        </section>
    {% else %}
        <section class="archive-year-section">
            <p>No posts found yet.</p>
        </section>
    {% endif %}
 </article>
