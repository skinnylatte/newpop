<!DOCTYPE html>
<html lang="en">
{% include "_head.html" %}

<body>

<a href="#main-content" class="skip-link">Skip to main content</a>

<header class="site-header">
	<div class="header-inner">
		<div class="site-brand">
			{% block site_title %}
				<p class="site-title"><a href="/">Popagandhi</a></p>
			{% endblock %}
			<p class="site-tagline">{{ site.description }}</p>
		</div>
		<nav class="site-nav" aria-label="Main">
			<a href="/">Home</a>
			<a href="/about">About</a>
			<a href="/photos">Photos</a>
			<a href="/food">Food</a>
			<a href="/now">Now</a>
			<a href="/search" aria-label="Search">
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" focusable="false" aria-hidden="true">
					<circle cx="11" cy="11" r="8"></circle>
					<path d="M21 21l-4.35-4.35"></path>
				</svg>
			</a>
		</nav>
		<button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme" title="Toggle theme">
			<span class="theme-toggle-icon theme-toggle-icon-sun" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="18" height="18" focusable="false">
					<circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"></circle>
					<path d="M12 2V5M12 19V22M4.93 4.93L7.05 7.05M16.95 16.95L19.07 19.07M2 12H5M19 12H22M4.93 19.07L7.05 16.95M16.95 7.05L19.07 4.93" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
				</svg>
			</span>
			<span class="theme-toggle-icon theme-toggle-icon-moon" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="18" height="18" focusable="false">
					<path d="M20 14.5A8.5 8.5 0 1 1 9.5 4 7 7 0 1 0 20 14.5Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
				</svg>
			</span>
		</button>
	</div>
</header>

<main id="main-content" class="site-main" {% if pagefindExclude %}data-pagefind-ignore="all"{% else %}data-pagefind-body{% endif %}>
	{% block main %}
	{% if not pagefindExclude and title %}
	<span class="visually-hidden" data-pagefind-meta="title">{{ title }}</span>
	{% endif %}
	{{ content | safe }}
	{% endblock %}
</main>

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-col">
			<h2 class="footer-heading">More</h2>
			<ul>
				<li><a href="/writing">Writing</a></li>
				<li><a href="/elsewhere">Elsewhere</a></li>
				<li><a href="/archives">Archives</a></li>
				<li><a href="/tags">Tags</a></li>
				<li><a href="/contact">Contact</a></li>
			</ul>
		</div>
		<div class="footer-col">
			<h2 class="footer-heading">Blogroll</h2>
			<ul>
				<li><a href="https://winnielim.org/" target="_blank" rel="noopener noreferrer">Winnie Lim<span class="visually-hidden"> (opens in new tab)</span></a></li>
				<li><a href="https://www.anildash.com/" target="_blank" rel="noopener noreferrer">Anil Dash<span class="visually-hidden"> (opens in new tab)</span></a></li>
				<li><a href="https://chronosaur.us/" target="_blank" rel="noopener noreferrer">Chronosaur.us<span class="visually-hidden"> (opens in new tab)</span></a></li>
				<li><a href="https://blog.byjasonli.com/" target="_blank" rel="noopener noreferrer">Jason Li<span class="visually-hidden"> (opens in new tab)</span></a></li>
				<li><a href="https://piccalil.li/blog/" target="_blank" rel="noopener noreferrer">Andy Bell<span class="visually-hidden"> (opens in new tab)</span></a></li>
				<li><a href="https://robinrendle.com/" target="_blank" rel="noopener noreferrer">Robin Rendle<span class="visually-hidden"> (opens in new tab)</span></a></li>
				<li><a href="https://bikes.emilyhorsman.com/" target="_blank" rel="noopener noreferrer">Emily's bike stuff<span class="visually-hidden"> (opens in new tab)</span></a></li>
			</ul>
		</div>
		<div class="footer-col footer-col--meta">
			<p class="footer-brand">Popagandhi</p>
			<p class="footer-tagline">punk rock since 2003</p>
			<p class="footer-copy">&copy; {{ site.copyrightYear }}</p>
			<div class="footer-social">
				<a href="https://hachyderm.io/@skinnylatte" target="_blank" rel="noopener noreferrer me">Mastodon<span class="visually-hidden"> (opens in new tab)</span></a>
				<a href="{{ metadata.feed.path }}">RSS</a>
				<a href="https://github.com/skinnylatte/newpop" target="_blank" rel="noopener noreferrer">GitHub<span class="visually-hidden"> (opens in new tab)</span></a>
			</div>
		</div>
	</div>
</footer>

</body>
</html>
