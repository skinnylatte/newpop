---
title: The Archives
layout: layout.njk
pagination:
  data: collections.postsByYear
  size: 1
  alias: year
  reverse: true
permalink: "archives/{{ year }}/"
eleventyExcludeFromCollections: true
---

<article class="archives">
    <h1>{{ title }} - {{ year }}</h1>
    <div class="date-metadata">Posts from {{ year }} across blog, photos, and bikes</div>

    <section class="archive-year-section">
        <h2>{{ year }} ({{ collections.postsByYear[year].length }} posts)</h2>

        <ul class="archive-posts-list">
            {% for post in collections.postsByYear[year] | reverse %}
            <li class="archive-post-item">
                <div class="archive-post-header">
                    <h3><a href="{{ post.url }}">{{ post.data.title | default("Untitled") }}</a></h3>
                    {% if post.date %}
                        <div class="date-metadata">{{ post.date | postDate }}</div>
                    {% endif %}
                </div>

                {% if post.data.excerpt %}
                    <div class="archive-post-excerpt">
                        <p>{{ post.data.excerpt }}</p>
                    </div>
                {% elif post.templateContent %}
                    <div class="archive-post-excerpt">
                        <p>{{ post.templateContent | striptags | trim | truncate(300, false, "…") }}</p>
                    </div>
                {% endif %}

                {% set visibleTags = post.data.tags | displayTags %}
                {% if visibleTags.length > 0 %}
                    <div class="archive-post-tags">
                        {% for tag in visibleTags %}
                            <a href="/tags/{{ tag | slug }}" class="tag-item">{{ tag }}</a>
                        {% endfor %}
                    </div>
                {% endif %}
            </li>
            {% endfor %}
        </ul>
    </section>
</article>

{% if pagination.pages.length > 1 %}
{% set paginationPrevLabel = "Previous Year" %}
{% set paginationNextLabel = "Next Year" %}
{% set paginationMessage = "Viewing " ~ year ~ " (" ~ (pagination.pageNumber + 1) ~ " of " ~ pagination.pages.length ~ ")" %}
{% set paginationAriaLabel = "Archive year pagination" %}
{% include "_pagepagination.html" %}
{% endif %}
