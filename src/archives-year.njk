---
title: The Archives
layout: layout.njk
pagination:
  data: collections.postsByYear
  size: 1
  alias: year
  reverse: true
permalink: "archives/{{ year }}/"
eleventyExcludeFromCollections: true
pagefindExclude: true
---

<article class="archives">
    <h1>{{ title }} - {{ year }}</h1>
    <div class="date-metadata">Posts from {{ year }} across blog, photos, and bikes</div>

    <section class="archive-year-section">
        <h2>{{ year }} ({{ collections.postsByYear[year].length }} posts)</h2>

        <ul class="archive-posts-list">
            {% for post in collections.postsByYear[year] | reverse %}
            {% set postCardItemClass = "archive-post-item" %}
            {% set postCardHeaderClass = "archive-post-header" %}
            {% set postCardTitleTag = "h3" %}
            {% set postCardShowContinueLink = false %}
            {% set postCardExcerptClass = "archive-post-excerpt" %}
            {% set postCardTagsClass = "archive-post-tags" %}
            {% set postCardExcerptLength = 300 %}
            {% include "_post_list_item.njk" %}
            {% endfor %}
        </ul>
    </section>
</article>

{% if pagination.pages.length > 1 %}
{% set paginationPrevLabel = "Previous Year" %}
{% set paginationNextLabel = "Next Year" %}
{% set paginationMessage = "Viewing " ~ year ~ " (" ~ (pagination.pageNumber + 1) ~ " of " ~ pagination.pages.length ~ ")" %}
{% set paginationAriaLabel = "Archive year pagination" %}
{% include "_pagepagination.html" %}
{% endif %}
