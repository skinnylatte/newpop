---
layout: layout.njk
title: Photos
pagefindExclude: true
eleventyExcludeFromCollections: true
---

<div class="photo-page">
  <h1 class="page-title">Photos</h1>
  <div class="photo-grid">
  {% set allPhotos = collections.photos | reverse %}
  {% for photo in allPhotos %}
    {% if photo.url and photo.url.startsWith("/photos/") %}
    {% set imgSrc = photo.data.thumbnail or (photo.templateContent | firstImage) %}
    {% set imgAlt = photo.data.thumbnailAlt or (photo.templateContent | firstImageAlt) or photo.data.title %}
    <a href="{{ photo.url }}" class="photo-grid-item">
      {% if imgSrc %}
        <img src="{{ imgSrc }}" alt="{{ imgAlt }}" loading="lazy" decoding="async">
      {% else %}
        <div class="photo-grid-placeholder"><span>{{ photo.data.title }}</span></div>
      {% endif %}
      <div class="photo-grid-overlay">
        <span class="photo-grid-title">{{ photo.data.title }}</span>
      </div>
    </a>
    {% endif %}
  {% endfor %}
  </div>
</div>
