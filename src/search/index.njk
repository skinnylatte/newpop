---
layout: layout.njk
title: Search
permalink: /search/
eleventyExcludeFromCollections: true
pagefindExclude: true
---

<h1 class="page-title">{{ title }}</h1>
<p class="search-intro">Search across posts, photos, bikes, food, and now entries.</p>
<div id="search" class="pagefind-search-root"></div>

<noscript>
  <p>Search needs JavaScript enabled.</p>
</noscript>

<script src="/pagefind/pagefind-ui.js" defer></script>
<script>
  window.addEventListener("DOMContentLoaded", function () {
    if (!window.PagefindUI) {
      return;
    }

    var initialQuery = new URLSearchParams(window.location.search).get("q") || "";

    new window.PagefindUI({
      element: "#search",
      showSubResults: false,
      showImages: false,
      excerptLength: 16,
      resetStyles: true,
      triggerSearchTerm: initialQuery
    });

    if (!initialQuery) {
      return;
    }

    window.setTimeout(function () {
      var input = document.querySelector("#search input.pagefind-ui__search-input");
      if (input) {
        input.focus();
      }
    }, 120);
  });
</script>
